<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Add subscription count to portal home -->
    <template id="portal_my_home_subscription" name="Portal My Home: Subscriptions"
              inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Subscriptions</t>
                <t t-set="url">/my/subscriptions</t>
                <t t-set="count" t-value="subscription_count"/>
                <t t-set="placeholder_count">subscription_count</t>
            </t>
        </xpath>
    </template>

    <!-- Subscriptions list -->
    <template id="portal_my_subscriptions" name="My Subscriptions">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Subscriptions</t>
            </t>
            <t t-if="not subscriptions">
                <div class="alert alert-warning">No subscriptions found.</div>
            </t>
            <t t-if="subscriptions" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Reference</th>
                        <th>Plan</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="subscriptions" t-as="sub">
                        <tr>
                            <td>
                                <a t-attf-href="/my/subscriptions/#{sub.id}">
                                    <t t-esc="sub.name"/>
                                </a>
                            </td>
                            <td><t t-esc="sub.template_id.name"/></td>
                            <td><t t-esc="sub.date_start"/></td>
                            <td><t t-esc="sub.date_end or '—'"/></td>
                            <td>
                                <span t-attf-class="badge #{sub.stage_id.category == 'in_progress' and 'bg-success' or 'bg-secondary'}">
                                    <t t-esc="sub.stage_id.name"/>
                                </span>
                            </td>
                            <td class="text-end">
                                <t t-esc="sub.recurring_total"/>
                                <t t-esc="sub.currency_id.symbol"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>

    <!-- Subscription detail -->
    <template id="portal_subscription_detail" name="Subscription Detail">
        <t t-call="portal.portal_layout">
            <t t-set="o_portal_fullwidth_alert" t-if="subscription.stage_id.category == 'in_progress'">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="edit_url" t-value="subscription.get_portal_url()"/>
                </t>
            </t>
            <div class="row mt16 o_portal_sidebar">
                <div class="col-lg-9">
                    <div class="o_portal_html_view shadow p-3">
                        <div class="d-flex justify-content-between mb-4">
                            <div>
                                <h4><t t-esc="subscription.name"/></h4>
                                <span class="text-muted"><t t-esc="subscription.template_id.name"/></span>
                            </div>
                            <div>
                                <span t-attf-class="badge fs-6 #{subscription.stage_id.category == 'in_progress' and 'bg-success' or 'bg-secondary'}">
                                    <t t-esc="subscription.stage_id.name"/>
                                </span>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-6">
                                <strong>Start Date:</strong>
                                <t t-esc="subscription.date_start"/>
                            </div>
                            <div class="col-6">
                                <strong>End Date:</strong>
                                <t t-esc="subscription.date_end or 'Indefinite'"/>
                            </div>
                        </div>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Service</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="subscription.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.product_id.name"/></td>
                                        <td class="text-end"><t t-esc="line.quantity"/></td>
                                        <td class="text-end"><t t-esc="line.price_unit"/></td>
                                        <td class="text-end"><t t-esc="line.price_subtotal"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Total per cycle</td>
                                    <td class="text-end fw-bold">
                                        <t t-esc="subscription.recurring_total"/>
                                        <t t-esc="subscription.currency_id.symbol"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
