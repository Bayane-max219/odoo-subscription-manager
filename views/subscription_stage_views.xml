<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_subscription_stage_list" model="ir.ui.view">
        <field name="name">subscription.stage.list</field>
        <field name="model">subscription.stage</field>
        <field name="arch" type="xml">
            <tree string="Subscription Stages">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category"/>
                <field name="fold"/>
            </tree>
        </field>
    </record>

    <record id="view_subscription_stage_form" model="ir.ui.view">
        <field name="name">subscription.stage.form</field>
        <field name="model">subscription.stage</field>
        <field name="arch" type="xml">
            <form string="Subscription Stage">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="sequence"/>
                        <field name="fold"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_subscription_stages" model="ir.actions.act_window">
        <field name="name">Subscription Stages</field>
        <field name="res_model">subscription.stage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
