<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_subscription_template_form" model="ir.ui.view">
        <field name="name">subscription.template.form</field>
        <field name="model">subscription.template</field>
        <field name="arch" type="xml">
            <form string="Subscription Template">
                <sheet>
                    <field name="active" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_subscriptions" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="active_subscription_count"/>
                                </span>
                                <span class="o_stat_text">Active</span>
                            </div>
                        </button>
                        <button name="action_view_subscriptions" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="subscription_count"/>
                                </span>
                                <span class="o_stat_text">Total</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template Name"/></h1>
                        <div class="o_row">
                            <field name="code" readonly="1" class="text-muted"/>
                        </div>
                    </div>
                    <group>
                        <group string="Billing">
                            <field name="billing_cycle"/>
                            <field name="custom_cycle_days"
                                   invisible="billing_cycle != 'custom'"/>
                            <field name="duration_months"/>
                            <field name="invoice_policy"/>
                            <field name="payment_term_id"/>
                            <field name="pricelist_id" groups="product.group_sale_pricelist"/>
                        </group>
                        <group string="Renewal">
                            <field name="auto_renew"/>
                            <field name="renewal_lead_days" invisible="not auto_renew"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Default Products">
                            <field name="product_ids" widget="many2many_kanban">
                                <kanban>
                                    <field name="display_name"/>
                                    <field name="lst_price"/>
                                    <field name="currency_id"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_global_click text-center p-2">
                                                <strong><field name="display_name"/></strong>
                                                <div class="text-muted">
                                                    <field name="lst_price" widget="monetary"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page string="Terms">
                            <field name="note" placeholder="Terms and conditions..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_subscription_template_list" model="ir.ui.view">
        <field name="name">subscription.template.list</field>
        <field name="model">subscription.template</field>
        <field name="arch" type="xml">
            <tree string="Subscription Templates">
                <field name="name"/>
                <field name="billing_cycle"/>
                <field name="duration_months"/>
                <field name="auto_renew"/>
                <field name="active_subscription_count" string="Active"/>
                <field name="subscription_count" string="Total"/>
            </tree>
        </field>
    </record>

    <record id="action_subscription_templates" model="ir.actions.act_window">
        <field name="name">Subscription Templates</field>
        <field name="res_model">subscription.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
