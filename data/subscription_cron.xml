<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="cron_generate_invoices" model="ir.cron">
        <field name="name">Subscription: Generate Recurring Invoices</field>
        <field name="model_id" ref="model_subscription_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="cron_send_renewal_reminders" model="ir.cron">
        <field name="name">Subscription: Send Renewal Reminder Emails</field>
        <field name="model_id" ref="model_subscription_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_renewal_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="cron_auto_renew" model="ir.cron">
        <field name="name">Subscription: Auto-Renew Subscriptions</field>
        <field name="model_id" ref="model_subscription_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_renew()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>
