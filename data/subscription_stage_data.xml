<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="stage_draft" model="subscription.stage">
        <field name="name">Draft</field>
        <field name="sequence">1</field>
        <field name="category">draft</field>
    </record>

    <record id="stage_active" model="subscription.stage">
        <field name="name">Active</field>
        <field name="sequence">10</field>
        <field name="category">in_progress</field>
    </record>

    <record id="stage_renewal_pending" model="subscription.stage">
        <field name="name">Renewal Pending</field>
        <field name="sequence">20</field>
        <field name="category">in_progress</field>
    </record>

    <record id="stage_cancelled" model="subscription.stage">
        <field name="name">Cancelled</field>
        <field name="sequence">90</field>
        <field name="category">cancelled</field>
        <field name="fold">True</field>
    </record>

    <record id="stage_closed" model="subscription.stage">
        <field name="name">Closed</field>
        <field name="sequence">100</field>
        <field name="category">closed</field>
        <field name="fold">True</field>
    </record>

    <record id="sequence_subscription" model="ir.sequence">
        <field name="name">Subscription</field>
        <field name="code">subscription.subscription</field>
        <field name="prefix">SUB/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_subscription_template" model="ir.sequence">
        <field name="name">Subscription Template</field>
        <field name="code">subscription.template</field>
        <field name="prefix">TMPL/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
