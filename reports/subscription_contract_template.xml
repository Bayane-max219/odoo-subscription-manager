<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_subscription_contract_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h2 class="text-primary">Subscription Contract</h2>
                                <h4><t t-esc="doc.name"/></h4>
                            </div>
                            <div class="col-6 text-end">
                                <div class="badge bg-success fs-6" t-if="doc.stage_id.category == 'in_progress'">
                                    ACTIVE
                                </div>
                                <div class="badge bg-secondary fs-6" t-else="">
                                    <t t-esc="doc.stage_id.name"/>
                                </div>
                            </div>
                        </div>

                        <!-- Parties -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h5>Service Provider</h5>
                                <address>
                                    <strong><t t-esc="doc.company_id.name"/></strong><br/>
                                    <t t-if="doc.company_id.street">
                                        <t t-esc="doc.company_id.street"/><br/>
                                    </t>
                                    <t t-if="doc.company_id.city">
                                        <t t-esc="doc.company_id.city"/>,
                                        <t t-esc="doc.company_id.country_id.name"/>
                                    </t>
                                </address>
                            </div>
                            <div class="col-6">
                                <h5>Customer</h5>
                                <address>
                                    <strong><t t-esc="doc.partner_id.name"/></strong><br/>
                                    <t t-if="doc.partner_id.street">
                                        <t t-esc="doc.partner_id.street"/><br/>
                                    </t>
                                    <t t-if="doc.partner_id.city">
                                        <t t-esc="doc.partner_id.city"/>,
                                        <t t-esc="doc.partner_id.country_id.name"/>
                                    </t>
                                </address>
                            </div>
                        </div>

                        <!-- Contract Details -->
                        <table class="table table-bordered mb-4">
                            <tbody>
                                <tr>
                                    <td class="fw-bold bg-light">Plan</td>
                                    <td><t t-esc="doc.template_id.name"/></td>
                                    <td class="fw-bold bg-light">Billing Cycle</td>
                                    <td><t t-esc="doc.billing_cycle"/></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">Start Date</td>
                                    <td><t t-esc="doc.date_start"/></td>
                                    <td class="fw-bold bg-light">End Date</td>
                                    <td><t t-esc="doc.date_end or 'Indefinite'"/></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">Auto-Renew</td>
                                    <td><t t-esc="'Yes' if doc.auto_renew else 'No'"/></td>
                                    <td class="fw-bold bg-light">Invoice Policy</td>
                                    <td><t t-esc="doc.invoice_policy"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Lines -->
                        <h5>Services Included</h5>
                        <table class="table table-striped">
                            <thead>
                                <tr class="bg-primary text-white">
                                    <th>Service</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.name or line.product_id.name"/></td>
                                        <td class="text-end"><t t-esc="line.quantity"/></td>
                                        <td class="text-end">
                                            <t t-esc="line.price_unit"/>
                                            <t t-esc="doc.currency_id.symbol"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="line.price_subtotal"/>
                                            <t t-esc="doc.currency_id.symbol"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Recurring Total</td>
                                    <td class="text-end fw-bold">
                                        <t t-esc="doc.recurring_total"/>
                                        <t t-esc="doc.currency_id.symbol"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Signatures -->
                        <div class="row mt-5">
                            <div class="col-5">
                                <p class="fw-bold">Service Provider</p>
                                <div style="border-top: 1px solid #000; margin-top: 50px; padding-top: 5px;">
                                    <t t-esc="doc.company_id.name"/>
                                </div>
                            </div>
                            <div class="col-5 offset-2">
                                <p class="fw-bold">Customer</p>
                                <div style="border-top: 1px solid #000; margin-top: 50px; padding-top: 5px;">
                                    <t t-esc="doc.partner_id.name"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
