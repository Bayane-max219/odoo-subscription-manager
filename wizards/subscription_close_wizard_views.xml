<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_subscription_close_wizard" model="ir.ui.view">
        <field name="name">subscription.close.wizard.form</field>
        <field name="model">subscription.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Close Subscriptions">
                <group>
                    <field name="subscription_ids" widget="many2many_tags" readonly="1"/>
                    <field name="close_reason"/>
                    <field name="close_date"/>
                    <field name="send_confirmation"/>
                    <field name="note" placeholder="Additional notes..."/>
                </group>
                <footer>
                    <button name="action_close" string="Close Subscriptions" type="object"
                            class="btn-primary" confirm="This action will close the selected subscriptions. Continue?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
